<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://724eczane.com/">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://724eczane.com/">
  <meta property="og:site_name" content="724eczane.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">

<%- include('partials/navbar') %>

<main>

<section class="hero-section py-5 text-white text-center">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <h1 class="display-4 fw-bold mb-3">
          <i class="fa-solid fa-pills me-3"></i>Türkiye Nöbetçi Eczane Rehberi
        </h1>
        <p class="lead mb-4">81 ilde, tüm ilçelerde nöbetçi eczaneleri anında bulun &mdash; 724eczane.com</p>
        <div class="input-group input-group-lg search-box mx-auto" style="max-width:560px;position:relative">
          <span class="input-group-text bg-white border-0"><i class="fa-solid fa-magnifying-glass text-danger"></i></span>
          <input type="text" id="citySearch" class="form-control border-0" placeholder="İl veya ilçe arayın..." autocomplete="off">
          <button id="micBtn" class="btn btn-mic" type="button" title="Sesli ara">
            <i class="fa-solid fa-microphone"></i>
          </button>
          <button class="btn btn-warning fw-bold" onclick="doSearch()">Ara</button>
        </div>
        <div id="searchResults" class="mt-1" style="position:relative;max-width:560px;margin:0 auto;"></div>
      </div>
    </div>
  </div>
</section>

<section class="py-4 bg-light border-bottom">
  <div class="container">
    <h2 class="h5 fw-bold mb-3 text-danger"><i class="fa-solid fa-star me-2"></i>Büyükşehirler</h2>
    <div class="row g-2">
      <% var majorSlugs = ['istanbul','ankara','izmir','bursa','antalya','adana','konya','gaziantep','mersin','kayseri','diyarbakir','samsun','trabzon','eskisehir','kocaeli','hatay','manisa','sakarya']; %>
      <% majorSlugs.forEach(function(slug){ var il = iller.find(function(i){ return i.slug===slug; }); if(il){ %>
      <div class="col-6 col-sm-4 col-md-3 col-lg-2">
        <a href="/nobetci-<%= il.slug %>" class="city-card d-block text-center p-3 rounded text-decoration-none">
          <i class="fa-solid fa-location-dot text-danger mb-1 d-block"></i>
          <span class="fw-semibold small"><%= il.name %></span>
        </a>
      </div>
      <% } }); %>
    </div>
  </div>
</section>

<section class="py-5">
  <div class="container">
    <h2 class="h4 fw-bold mb-4 text-danger">
      <i class="fa-solid fa-list me-2"></i>Tüm İller (A-Z)
    </h2>
    <div class="row g-2">
      <% iller.slice().sort(function(a,b){return a.name.localeCompare(b.name,'tr');}).forEach(function(il){ %>
      <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-2">
        <a href="/nobetci-<%= il.slug %>" class="province-card d-flex align-items-center gap-2 p-2 rounded text-decoration-none">
          <span class="plate-badge"><%= il.plate %></span>
          <span class="fw-medium"><%= il.name %></span>
        </a>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="py-5 bg-light">
  <div class="container">
    <div class="row g-4 align-items-center">
      <div class="col-md-6">
        <h2 class="h4 fw-bold text-danger mb-3">
          <i class="fa-solid fa-circle-info me-2"></i>Nöbetçi Eczane Nasıl Bulunur?
        </h2>
        <ul class="list-unstyled info-list">
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>Yukarıdan ilinizi seçin</li>
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>İlçenizi seçerek daha dar arama yapın</li>
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>Dün, bugün veya yarın sekmesiyle tarih seçin</li>
          <li><i class="fa-solid fa-check-circle text-success me-2"></i>Yol tarifi butonuyla konum izni verin, haritada rota çizilir</li>
        </ul>
      </div>
      <div class="col-md-6">
        <div class="info-card p-4 rounded-3">
          <h3 class="h5 fw-bold mb-2"><i class="fa-solid fa-clock-rotate-left me-2 text-warning"></i>Nöbet Saatleri</h3>
          <p class="text-muted small mb-0">Nöbetçi eczaneler genellikle saat <strong>09:00 – 09:00</strong> (24 saat) hizmet verir. Tatil ve hafta sonu nöbetleri farklılık gösterebilir.</p>
        </div>
      </div>
    </div>
  </div>
</section>

</main>

<%- include('partials/footer') %>

<script>window._illerData = <%- JSON.stringify(iller) %>;</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/app.js"></script>
<script>
(function () {
  var micBtn = document.getElementById('micBtn');
  if (!micBtn) return;
  var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) { micBtn.style.display = 'none'; return; }
  var rec = new SR();
  rec.lang = 'tr-TR';
  rec.continuous = false;
  rec.interimResults = false;
  var active = false;
  micBtn.addEventListener('click', function () {
    if (active) { rec.stop(); return; }
    rec.start();
  });
  rec.onstart = function () {
    active = true;
    micBtn.classList.add('mic-active');
    micBtn.innerHTML = '<i class="fa-solid fa-microphone-slash"></i>';
    micBtn.title = 'Durdurmak için tıklayın';
  };
  rec.onresult = function (e) {
    var text = e.results[0][0].transcript;
    var inp = document.getElementById('citySearch');
    inp.value = text;
    inp.dispatchEvent(new Event('input'));
  };
  rec.onend = function () {
    active = false;
    micBtn.classList.remove('mic-active');
    micBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
    micBtn.title = 'Sesli ara';
  };
  rec.onerror = function () {
    active = false;
    micBtn.classList.remove('mic-active');
    micBtn.innerHTML = '<i class="fa-solid fa-microphone"></i>';
    micBtn.title = 'Sesli ara';
  };
})();
</script>
</body>
</html>
