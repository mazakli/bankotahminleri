<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<%- include('partials/hr-navbar') %>

<!-- Hero -->
<section class="hr-hero text-white">
  <div class="container">
    <h1 class="mb-2">
      <i class="fa-solid fa-chart-bar me-2"></i>AGF Tablosu
    </h1>
    <p class="mb-0 opacity-75" style="max-width:640px;">
      <i class="fa-solid fa-circle-info me-1"></i>
      AGF (Anlaşmalı Ganyan Fiyatı), TJK tarafından koşu başlamadan önce açıklanan
      resmi olasılık fiyatlarıdır. Düşük AGF = yüksek favorilik.
    </p>
    <div class="d-flex gap-3 mt-3 flex-wrap">
      <span class="badge" style="background:rgba(255,255,255,0.15); font-size:0.78rem; padding:6px 12px;">
        <span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#198754;"></span>
        AGF &lt; 3 — Güçlü Favori
      </span>
      <span class="badge" style="background:rgba(255,255,255,0.15); font-size:0.78rem; padding:6px 12px;">
        <span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#ffc107;"></span>
        AGF 3–6 — Favori
      </span>
      <span class="badge" style="background:rgba(255,255,255,0.15); font-size:0.78rem; padding:6px 12px;">
        <span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#fd7e14;"></span>
        AGF 6–12 — Orta
      </span>
      <span class="badge" style="background:rgba(255,255,255,0.15); font-size:0.78rem; padding:6px 12px;">
        <span class="d-inline-block rounded-circle me-1" style="width:10px;height:10px;background:#6c757d;"></span>
        AGF &gt; 12 — Uzun İhtimal
      </span>
    </div>
  </div>
</section>

<div class="container py-4">

  <!-- Date info -->
  <div class="d-flex align-items-center gap-2 mb-4">
    <span class="text-muted"><i class="fa-regular fa-calendar me-1"></i>Tarih:</span>
    <strong><%= tarih %></strong>
    <a href="/agf" class="btn btn-sm btn-outline-secondary ms-2">Bugün</a>
  </div>

  <!-- Hippodrome Tabs -->
  <ul class="nav nav-tabs hipodromo-tabs mb-4" id="hipTabs" role="tablist">
    <% data.forEach(function(hip, idx) { %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= idx === 0 ? 'active' : '' %>"
        id="tab-<%= hip.id %>"
        data-bs-toggle="tab" data-bs-target="#pane-<%= hip.id %>"
        type="button" role="tab">
        <i class="fa-solid fa-location-dot me-1"></i><%= hip.kisa %>
      </button>
    </li>
    <% }) %>
  </ul>

  <div class="tab-content" id="hipTabContent">
    <% data.forEach(function(hip, hipIdx) { %>
    <div class="tab-pane fade <%= hipIdx === 0 ? 'show active' : '' %>" id="pane-<%= hip.id %>" role="tabpanel">

      <h4 class="text-hr-green fw-bold mb-3">
        <i class="fa-solid fa-horse me-2"></i><%= hip.ad %>
      </h4>

      <!-- Accordion for races -->
      <div class="accordion kosu-accordion" id="accord-<%= hip.id %>">
        <% hip.kosular.forEach(function(kosu, kosuIdx) { %>
        <div class="accordion-item border mb-2 rounded">
          <h2 class="accordion-header" id="head-<%= hip.id %>-<%= kosu.no %>">
            <button class="accordion-button <%= kosuIdx > 0 ? 'collapsed' : '' %> rounded"
              type="button"
              data-bs-toggle="collapse"
              data-bs-target="#col-<%= hip.id %>-<%= kosu.no %>"
              aria-expanded="<%= kosuIdx === 0 ? 'true' : 'false' %>">
              <div class="d-flex align-items-center gap-3 w-100 flex-wrap">
                <span class="horse-no me-1"><%= kosu.no %></span>
                <span class="fw-bold"><%= kosu.no %>. KOŞU — <%= kosu.saat %></span>
                <span class="text-muted fw-normal" style="font-size:0.85rem;">
                  <%= kosu.mesafe %>m <%= kosu.pist %> | <%= kosu.yas %>
                </span>
                <div class="ms-auto d-flex gap-2 me-3">
                  <% if (kosu.durum === 'Yarış Tamamlandı') { %>
                  <span class="badge bg-secondary">
                    <i class="fa-solid fa-flag-checkered me-1"></i>Tamamlandı
                  </span>
                  <% } else { %>
                  <span class="badge" style="background:#1a6b3a;">
                    <i class="fa-solid fa-circle-play me-1"></i>Başlamadı
                  </span>
                  <% } %>
                  <span class="badge" style="background:#c8a400; color:#1a1a1e;">
                    <%= kosu.ikramiyeStr %>
                  </span>
                </div>
              </div>
            </button>
          </h2>
          <div id="col-<%= hip.id %>-<%= kosu.no %>"
            class="accordion-collapse collapse <%= kosuIdx === 0 ? 'show' : '' %>"
            data-bs-parent="#accord-<%= hip.id %>">
            <div class="accordion-body p-0">
              <div class="table-responsive">
                <table class="table horse-table mb-0">
                  <thead>
                    <tr>
                      <th style="width:45px;">No</th>
                      <th>At Adı</th>
                      <th style="width:80px;" class="text-center">AGF</th>
                      <th style="width:90px;" class="text-center">Ganyan</th>
                      <th style="width:90px;" class="text-center">Plase</th>
                    </tr>
                  </thead>
                  <tbody>
                    <%
                      var sortedAtlar = kosu.atlar.slice().sort(function(a,b){ return a.agf - b.agf; });
                      var top3agf = sortedAtlar.slice(0,3).map(function(a){ return a.no; });
                      var minAgf2 = sortedAtlar[0] ? sortedAtlar[0].agf : 999;
                    %>
                    <% kosu.atlar.forEach(function(at) {
                      var isFavori = at.agf === minAgf2;
                      var isTop3   = top3agf.indexOf(at.no) !== -1;
                      var agfClass = at.agf < 3 ? 'agf-hot' : at.agf <= 6 ? 'text-warning fw-bold' : at.agf <= 12 ? 'agf-warm' : 'agf-cold';
                    %>
                    <tr class="<%= isFavori ? 'table-success' : '' %>">
                      <td>
                        <span class="horse-no"><%= at.no %></span>
                      </td>
                      <td>
                        <span class="<%= isTop3 ? 'fw-bold' : '' %>"><%= at.ad %></span>
                        <% if (isFavori) { %>
                        <span class="badge badge-favori ms-1">
                          <i class="fa-solid fa-star me-1"></i>FAVORİ
                        </span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <strong class="<%= agfClass %>" style="font-size:1rem;"><%= at.agf %></strong>
                      </td>
                      <td class="text-center text-muted"><%= at.ganyan %></td>
                      <td class="text-center text-muted"><%= at.plase %></td>
                    </tr>
                    <% }) %>
                  </tbody>
                </table>
              </div>

              <!-- Favori bar -->
              <% var favAt = kosu.favori; %>
              <div class="px-3 py-2 d-flex align-items-center gap-2 flex-wrap"
                   style="background:#e8f5ec; border-top:1px solid #dee2e6; font-size:0.82rem;">
                <i class="fa-solid fa-star text-warning"></i>
                <strong>Koşu Favorisi:</strong>
                <span>#<%= favAt.no %> <%= favAt.ad %></span>
                <span class="text-muted">— AGF: <strong><%= favAt.agf %></strong></span>
                <span class="text-muted">| Ganyan: <strong><%= favAt.ganyan %></strong></span>
                <span class="text-muted">| Plase: <strong><%= favAt.plase %></strong></span>
                <a href="/bulten?tarih=<%= tarih %>" class="ms-auto btn btn-sm"
                   style="background:var(--hr-green); color:#fff; font-size:0.75rem;">
                  Bülten Detayı
                </a>
              </div>
            </div>
          </div>
        </div>
        <% }) %>
      </div>

    </div>
    <% }) %>
  </div>

</div>

<%- include('partials/hr-footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
