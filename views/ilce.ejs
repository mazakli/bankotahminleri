<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= description %>">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://724eczane.com/nobetci-<%= il.slug %>-<%= ilce.slug %>">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://724eczane.com/nobetci-<%= il.slug %>-<%= ilce.slug %>">
  <meta property="og:site_name" content="724eczane.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link rel="stylesheet" href="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.css">
  <link rel="stylesheet" href="/css/style.css">
  <style>.leaflet-routing-container{display:none!important}</style>
</head>
<body class="d-flex flex-column min-vh-100">

<%- include('partials/navbar') %>

<main class="flex-grow-1">
<div class="container py-4">

  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/" class="text-danger text-decoration-none"><i class="fa-solid fa-house me-1"></i>Ana Sayfa</a></li>
      <li class="breadcrumb-item"><a href="/nobetci-<%= il.slug %>" class="text-danger text-decoration-none"><%= il.name %></a></li>
      <li class="breadcrumb-item active"><%= ilce.name %></li>
    </ol>
  </nav>

  <h1 class="h2 fw-bold text-danger mb-1">
    <i class="fa-solid fa-pills me-2"></i><%= il.name %> <%= ilce.name %> Nöbetçi Eczaneleri
  </h1>
  <p class="text-muted mb-4">Aşağıdan tarih seçerek nöbetçi eczane listesini görüntüleyin.</p>

  <ul class="nav nav-tabs day-tabs mb-3" id="dayTabs">
    <li class="nav-item">
      <button class="nav-link day-tab" data-date="<%= today.dun.iso %>">
        <span class="d-none d-sm-inline">Dün &mdash; </span><%= today.dun.label %>
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link day-tab active" data-date="<%= today.bugun.iso %>">
        <i class="fa-solid fa-circle-dot me-1"></i><strong>Bugün</strong>
        <span class="d-none d-sm-inline"> &mdash; <%= today.bugun.label %></span>
      </button>
    </li>
    <li class="nav-item">
      <button class="nav-link day-tab" data-date="<%= today.yarin.iso %>">
        <span class="d-none d-sm-inline">Yarın &mdash; </span><%= today.yarin.label %>
      </button>
    </li>
  </ul>

  <div class="alert alert-info py-2 px-3 mb-4 d-flex align-items-center gap-2" style="font-size:0.85rem">
    <i class="fa-solid fa-location-crosshairs text-primary flex-shrink-0"></i>
    <span><strong>Yol Tarifi:</strong> Butona tıkladığınızda tarayıcınız <strong>konum izni</strong> isteyecektir. İzin vermeniz halinde bulunduğunuz noktadan eczaneye rota çizilir.</span>
  </div>

  <div class="row g-4">

    <div class="col-md-3 order-md-last">
      <div class="sidebar-card">
        <div class="sidebar-header">
          <i class="fa-solid fa-map-pin me-2"></i><%= il.name %> İlçeleri
        </div>
        <div class="sidebar-body">
          <a href="/nobetci-<%= il.slug %>" class="sidebar-link">
            <i class="fa-solid fa-city me-1"></i>Tüm İlçeler
          </a>
          <% il.districts.forEach(function(d){ %>
          <a href="/nobetci-<%= il.slug %>-<%= d.slug %>" class="sidebar-link<%= d.slug === ilce.slug ? ' active' : '' %>"><%= d.name %></a>
          <% }); %>
        </div>
      </div>
    </div>

    <div class="col-md-9">
      <div id="loadingSpinner" class="text-center py-5">
        <div class="spinner-border text-danger" style="width:3rem;height:3rem" role="status"></div>
        <p class="mt-3 text-muted">Nöbetçi eczaneler yükleniyor...</p>
      </div>
      <div id="pharmacyTableWrap" style="display:none">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <span id="pharmacyCount" class="badge bg-danger fs-6"></span>
          <input type="text" id="tableSearch" class="form-control form-control-sm w-auto" placeholder="Tabloda ara...">
        </div>
        <div class="table-responsive">
          <table class="table table-hover pharmacy-table">
            <thead>
              <tr>
                <th>#</th>
                <th><i class="fa-solid fa-prescription-bottle me-1"></i>Eczane Adı</th>
                <th><i class="fa-solid fa-location-dot me-1"></i>Adres</th>
                <th><i class="fa-solid fa-phone me-1"></i>Telefon</th>
                <th><i class="fa-solid fa-map me-1"></i>Yol Tarifi</th>
              </tr>
            </thead>
            <tbody id="pharmacyTbody"></tbody>
          </table>
        </div>
      </div>
      <div id="noDataMsg" class="alert alert-warning" style="display:none">
        <i class="fa-solid fa-triangle-exclamation me-2"></i>Bu tarih için nöbetçi eczane bulunamadı.
      </div>
      <div id="errorMsg" class="alert alert-danger" style="display:none">
        <i class="fa-solid fa-circle-xmark me-2"></i>Veri yüklenirken hata oluştu. Lütfen tekrar deneyin.
      </div>
    </div>

  </div>
</div>
</main>

<%- include('partials/footer') %>

<div class="modal fade" id="mapsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-red text-white">
        <h5 class="modal-title"><i class="fa-solid fa-map-location-dot me-2"></i><span id="modalPharmacyName">Yol Tarifi</span></h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body p-0">
        <div id="mapContainer" style="width:100%;height:450px;"></div>
      </div>
      <div class="modal-footer">
        <a id="mapsExternalLink" href="#" target="_blank" rel="noopener" class="btn btn-danger btn-sm">
          <i class="fa-solid fa-diamond-turn-right me-1"></i>Google Maps'te Aç
        </a>
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Kapat</button>
      </div>
    </div>
  </div>
</div>

<script>
window.PAGE_IL = '<%- il.name.replace(/'/g, "\\'") %>';
window.PAGE_ILSLUG = '<%= il.slug %>';
window.PAGE_ILCE = '<%- ilce.name.replace(/'/g, "\\'") %>';
window.PAGE_ILCESLUG = '<%= ilce.slug %>';
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-routing-machine@3.2.12/dist/leaflet-routing-machine.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
