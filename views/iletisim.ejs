<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/hr-head') %>
</head>
<body>

<%- include('partials/hr-navbar') %>

<section class="py-4 text-white text-center" style="background:#1a6b3a;">
  <div class="container">
    <h1 class="h2 fw-bold mb-2"><i class="fa-solid fa-envelope me-2"></i>İletişim</h1>
    <p class="mb-0 opacity-75">Soru, öneri ve geri bildirimleriniz için bize ulaşın</p>
  </div>
</section>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <!-- İletişim Kartları -->
      <div class="row g-3 mb-5">
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body p-4">
              <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:52px;height:52px;background:#e8f5ec;">
                <i class="fa-solid fa-globe" style="color:#1a6b3a; font-size:1.3rem;"></i>
              </div>
              <h6 class="fw-bold mb-1">Web Sitesi</h6>
              <p class="text-muted mb-0" style="font-size:0.85rem;">bankotahminleri.com</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body p-4">
              <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:52px;height:52px;background:#e8f5ec;">
                <i class="fa-solid fa-database" style="color:#1a6b3a; font-size:1.3rem;"></i>
              </div>
              <h6 class="fw-bold mb-1">Veri Kaynağı</h6>
              <p class="text-muted mb-0" style="font-size:0.85rem;">
                <a href="/veri-bilgisi" style="color:#1a6b3a; text-decoration:none;">Veri bilgisi sayfası</a>
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm h-100 text-center">
            <div class="card-body p-4">
              <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:52px;height:52px;background:#e8f5ec;">
                <i class="fa-solid fa-shield-halved" style="color:#1a6b3a; font-size:1.3rem;"></i>
              </div>
              <h6 class="fw-bold mb-1">Gizlilik</h6>
              <p class="text-muted mb-0" style="font-size:0.85rem;">
                <a href="/gizlilik" style="color:#1a6b3a; text-decoration:none;">Gizlilik politikası</a>
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- İletişim Formu -->
      <div class="card border-0 shadow-sm">
        <div class="card-header py-3 px-4 fw-bold" style="background:#1a6b3a; color:#fff; border-radius:8px 8px 0 0;">
          <i class="fa-solid fa-paper-plane me-2"></i>Mesaj Gönderin
        </div>
        <div class="card-body p-4">
          <div id="contactFormWrap">
            <form id="contactForm" novalidate>
              <div class="row g-3 mb-3">
                <div class="col-md-6">
                  <label class="form-label fw-semibold" style="font-size:0.9rem;">Ad Soyad <span class="text-danger">*</span></label>
                  <input type="text" id="cName" class="form-control" placeholder="Adınız soyadınız" required autocomplete="name">
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-semibold" style="font-size:0.9rem;">E-posta <span class="text-danger">*</span></label>
                  <input type="email" id="cEmail" class="form-control" placeholder="ornek@mail.com" required autocomplete="email">
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label fw-semibold" style="font-size:0.9rem;">Konu <span class="text-danger">*</span></label>
                <select id="cSubject" class="form-select" required>
                  <option value="">— Konu seçin —</option>
                  <option value="Hata Bildirimi">Hata Bildirimi</option>
                  <option value="Veri Hatası">Veri Hatası</option>
                  <option value="Öneri">Öneri</option>
                  <option value="İş Birliği">İş Birliği</option>
                  <option value="Diğer">Diğer</option>
                </select>
              </div>
              <div class="mb-4">
                <label class="form-label fw-semibold" style="font-size:0.9rem;">Mesajınız <span class="text-danger">*</span></label>
                <textarea id="cMessage" class="form-control" rows="5" placeholder="Mesajınızı buraya yazın..." required></textarea>
              </div>
              <div id="formError" class="alert alert-danger d-none" role="alert"></div>
              <button type="submit" class="btn fw-bold px-5" style="background:#1a6b3a; color:#fff;">
                <i class="fa-solid fa-paper-plane me-2"></i>Gönder
              </button>
            </form>
          </div>
          <div id="contactSuccess" class="text-center py-5 d-none">
            <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;background:#e8f5ec;">
              <i class="fa-solid fa-circle-check" style="color:#1a6b3a; font-size:2rem;"></i>
            </div>
            <h5 class="fw-bold mb-2">Mesajınız Alındı!</h5>
            <p class="text-muted mb-0">En kısa sürede geri dönüş yapılacaktır. Teşekkür ederiz.</p>
          </div>
        </div>
      </div>

      <!-- Yasal Uyarı -->
      <div class="mt-4 p-3 rounded-3" style="background:#f8f9fa; font-size:0.82rem; color:#6c757d;">
        <i class="fa-solid fa-circle-info me-2" style="color:#1a6b3a;"></i>
        bankotahminleri.com bir bahis sitesi değildir. Bahis ile ilgili talepler değerlendirmeye alınmaz.
        Resmi bahis için <a href="https://www.tjk.org" target="_blank" rel="noopener" style="color:#1a6b3a;">TJK.org</a>'u ziyaret edin.
      </div>

    </div>
  </div>
</div>

<%- include('partials/hr-footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.getElementById('contactForm').addEventListener('submit', function(e) {
  e.preventDefault();
  var name    = document.getElementById('cName').value.trim();
  var email   = document.getElementById('cEmail').value.trim();
  var subject = document.getElementById('cSubject').value;
  var message = document.getElementById('cMessage').value.trim();
  var errEl   = document.getElementById('formError');
  errEl.classList.add('d-none');
  if (!name || !email || !subject || !message) {
    errEl.textContent = 'Lütfen tüm alanları doldurun.';
    errEl.classList.remove('d-none');
    return;
  }
  if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
    errEl.textContent = 'Geçerli bir e-posta adresi girin.';
    errEl.classList.remove('d-none');
    return;
  }
  document.getElementById('contactFormWrap').classList.add('d-none');
  document.getElementById('contactSuccess').classList.remove('d-none');
});
</script>
</body>
</html>
