<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('partials/hr-head') %>
</head>
<body>

<%- include('partials/hr-navbar') %>

<!-- Hero -->
<section class="hr-hero text-white">
  <div class="container">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
      <div>
        <h1 class="mb-1">
          <i class="fa-solid fa-trophy me-2"></i>Yarış Sonuçları
        </h1>
        <p class="mb-0 opacity-75">
          Koşu sonuçları, derece süreleri ve ikramiye ödemeleri
        </p>
      </div>
    </div>
  </div>
</section>

<div class="container py-4">

  <% if (typeof kaynakGercek !== 'undefined' && !kaynakGercek) { %>
  <div class="alert alert-warning d-flex align-items-center gap-2 py-2 mb-3" role="alert">
    <i class="fa-solid fa-triangle-exclamation"></i>
    <span><strong>Demo Modu:</strong> TJK API'ye şu an erişilemiyor. Örnek veriler gösteriliyor.</span>
  </div>
  <% } else if (typeof kaynakGercek !== 'undefined' && kaynakGercek) { %>
  <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" role="alert">
    <i class="fa-solid fa-circle-check"></i>
    <span><strong>Canlı Veri:</strong> TJK resmi verisi kullanılıyor.</span>
  </div>
  <% } %>

  <!-- Date picker -->
  <div class="tarih-picker mb-4">
    <form method="GET" action="/sonuclar" class="d-flex flex-column flex-md-row gap-3 align-items-md-end">
      <div>
        <label class="form-label fw-bold mb-1" style="font-size:0.875rem;">
          <i class="fa-regular fa-calendar me-1 text-hr-green"></i>Tarih Seçin
        </label>
        <input type="date" name="tarih" value="<%= tarih %>"
          max="<%= new Date(Date.now() + 3*60*60*1000).toISOString().split('T')[0] %>"
          class="form-control" style="border:2px solid var(--hr-green); max-width:200px;">
      </div>
      <button type="submit" class="btn text-white"
        style="background:var(--hr-green); border-color:var(--hr-green);">
        <i class="fa-solid fa-magnifying-glass me-1"></i>Sonuçları Gör
      </button>
    </form>

    <!-- Quick date links -->
    <%
      var _now = new Date(Date.now() + 3 * 60 * 60 * 1000);
      var _iso = function(d) { return d.toISOString().split('T')[0]; };
      var _today   = _iso(_now);
      var _dun     = _iso(new Date(_now.getTime() - 86400000));
      var _uc      = _iso(new Date(_now.getTime() - 3*86400000));
      var _yedi    = _iso(new Date(_now.getTime() - 7*86400000));
    %>
    <div class="d-flex gap-2 mt-3 flex-wrap">
      <a href="/sonuclar?tarih=<%= _today %>"
         class="tarih-btn <%= tarih === _today ? 'active' : '' %>">
        Bugün
      </a>
      <a href="/sonuclar?tarih=<%= _dun %>"
         class="tarih-btn <%= tarih === _dun ? 'active' : '' %>">
        Dün
      </a>
      <a href="/sonuclar?tarih=<%= _uc %>"
         class="tarih-btn <%= tarih === _uc ? 'active' : '' %>">
        3 Gün Önce
      </a>
      <a href="/sonuclar?tarih=<%= _yedi %>"
         class="tarih-btn <%= tarih === _yedi ? 'active' : '' %>">
        7 Gün Önce
      </a>
    </div>
  </div>

  <!-- Today badge -->
  <% if (tarih === _today) { %>
  <div class="alert alert-warning d-flex align-items-center gap-2 mb-4" role="alert">
    <i class="fa-solid fa-circle-info"></i>
    <strong class="badge bg-warning text-dark me-1">BUGÜN</strong>
    Bugünün sonuçları canlı olarak güncellenmektedir. Bazı koşular henüz tamamlanmamış olabilir.
  </div>
  <% } %>

  <!-- Hippodrome Tabs -->
  <ul class="nav nav-tabs hipodromo-tabs mb-4" id="hipTabs" role="tablist">
    <% data.forEach(function(hip, idx) { %>
    <li class="nav-item" role="presentation">
      <button class="nav-link <%= idx === 0 ? 'active' : '' %>"
        id="tab-<%= hip.id %>"
        data-bs-toggle="tab" data-bs-target="#pane-<%= hip.id %>"
        type="button" role="tab">
        <i class="fa-solid fa-location-dot me-1"></i><%= hip.kisa %>
      </button>
    </li>
    <% }) %>
  </ul>

  <div class="tab-content" id="hipTabContent">
    <% data.forEach(function(hip, hipIdx) { %>
    <div class="tab-pane fade <%= hipIdx === 0 ? 'show active' : '' %>" id="pane-<%= hip.id %>" role="tabpanel">

      <h4 class="text-hr-green fw-bold mb-4">
        <i class="fa-solid fa-horse me-2"></i><%= hip.ad %>
      </h4>

      <% hip.kosular.forEach(function(kosu, kosuIdx) {
        // Races 5-7 on today's date show as "pending"
        var isPending = (tarih === _today && kosuIdx >= 4);
      %>
      <div class="race-card mb-4">
        <div class="race-card-header d-flex flex-wrap align-items-center justify-content-between gap-2">
          <div class="d-flex align-items-center gap-3">
            <span class="race-no"><%= kosu.no %></span>
            <div>
              <span class="fw-bold fs-6"><%= kosu.no %>. KOŞU — <%= kosu.saat %></span>
              <div style="font-size:0.82rem; opacity:0.85;">
                <%= kosu.mesafe %>m <%= kosu.pist %> | <%= kosu.yas %> | <%= kosu.cins %>
              </div>
            </div>
          </div>
          <div class="d-flex align-items-center gap-2">
            <% if (isPending) { %>
            <span class="badge bg-secondary">
              <i class="fa-regular fa-clock me-1"></i>Bekleniyor
            </span>
            <% } else { %>
            <span class="badge" style="background:#c8a400; color:#1a1a1e;">
              <i class="fa-solid fa-flag-checkered me-1"></i>Tamamlandı
            </span>
            <% } %>
            <span class="badge" style="background:rgba(255,255,255,0.2);">
              <%= kosu.ikramiyeStr %>
            </span>
          </div>
        </div>

        <% if (isPending) { %>
        <!-- Pending race -->
        <div class="p-5 text-center text-muted">
          <i class="fa-solid fa-circle-play fa-3x mb-3" style="color:#dee2e6;"></i>
          <p class="mb-0 fw-bold">Sonuçlar bekleniyor...</p>
          <p class="small mb-0">Bu koşu henüz tamamlanmadı. Koşu saati: <%= kosu.saat %></p>
        </div>
        <% } else { %>

        <!-- Results table -->
        <div class="table-responsive">
          <table class="table horse-table mb-0">
            <thead>
              <tr>
                <th style="width:70px;" class="text-center">Derece</th>
                <th style="width:50px;" class="text-center">No</th>
                <th>At Adı</th>
                <th>Jokey</th>
                <th style="width:100px;" class="text-center">Süre</th>
                <th style="width:70px;" class="text-center">Kilo</th>
              </tr>
            </thead>
            <tbody>
              <% kosu.sonuclar.forEach(function(s) { %>
              <tr class="<%= s.gelisSirasi === 1 ? 'sonuc-1' : s.gelisSirasi === 2 ? 'sonuc-2' : s.gelisSirasi === 3 ? 'sonuc-3' : '' %>">
                <td class="text-center">
                  <% if (s.gelisSirasi === 1) { %>
                  <span class="badge" style="background:#c8a400; color:#1a1a1e; font-size:0.9rem;">1.</span>
                  <% } else if (s.gelisSirasi === 2) { %>
                  <span class="badge bg-secondary">2.</span>
                  <% } else if (s.gelisSirasi === 3) { %>
                  <span class="badge" style="background:#cd7f32; color:#fff;">3.</span>
                  <% } else { %>
                  <span class="text-muted"><%= s.gelisSirasi %>.</span>
                  <% } %>
                </td>
                <td class="text-center">
                  <span class="horse-no"><%= s.atNo %></span>
                </td>
                <td>
                  <strong class="<%= s.gelisSirasi <= 3 ? '' : 'fw-normal' %>"><%= s.atAd %></strong>
                </td>
                <td><%= s.jokey %></td>
                <td class="text-center">
                  <span class="derece-badge"><%= s.derece %></span>
                </td>
                <td class="text-center text-muted"><%= s.handikap %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <!-- Payout card -->
        <div class="p-3" style="background:#f8f9fa; border-top:1px solid #dee2e6;">
          <h6 class="fw-bold mb-3">
            <i class="fa-solid fa-coins me-2 text-hr-gold"></i>İkramiye Ödemeleri
          </h6>
          <div class="row g-3">
            <div class="col-md-8">
              <div class="payout-card p-3">
                <div class="row g-0">
                  <div class="col-6 col-md-4 payout-item pe-3">
                    <div class="payout-label">Ganyan</div>
                    <div class="payout-val">
                      #<%= kosu.odemeler.ganyanNo %> — <%= kosu.odemeler.ganyan %> TL
                    </div>
                    <small class="text-muted" style="font-size:0.75rem;"><%= kosu.odemeler.ganyanAt %></small>
                  </div>
                  <div class="col-6 col-md-4 payout-item pe-3">
                    <div class="payout-label">Plase 1.</div>
                    <div class="payout-val">
                      #<%= kosu.odemeler.plaseNo1 %> — <%= kosu.odemeler.plase1 %> TL
                    </div>
                    <small class="text-muted" style="font-size:0.75rem;"><%= kosu.odemeler.plaseAt1 %></small>
                  </div>
                  <div class="col-6 col-md-4 payout-item pe-3">
                    <div class="payout-label">Plase 2.</div>
                    <div class="payout-val">
                      #<%= kosu.odemeler.plaseNo2 %> — <%= kosu.odemeler.plase2 %> TL
                    </div>
                    <small class="text-muted" style="font-size:0.75rem;"><%= kosu.odemeler.plaseAt2 %></small>
                  </div>
                  <% if (kosu.odemeler.plaseAt3) { %>
                  <div class="col-6 col-md-4 payout-item pe-3">
                    <div class="payout-label">Plase 3.</div>
                    <div class="payout-val">
                      #<%= kosu.odemeler.plaseNo3 %> — <%= kosu.odemeler.plase3 %> TL
                    </div>
                    <small class="text-muted" style="font-size:0.75rem;"><%= kosu.odemeler.plaseAt3 %></small>
                  </div>
                  <% } %>
                  <div class="col-6 col-md-4 payout-item pe-3">
                    <div class="payout-label">Çifte (<%= kosu.odemeler.cifteStr %>)</div>
                    <div class="payout-val"><%= kosu.odemeler.cifte %> TL</div>
                  </div>
                  <div class="col-6 col-md-4 payout-item pe-3">
                    <div class="payout-label">Sürpriz (<%= kosu.odemeler.surprizStr %>)</div>
                    <div class="payout-val"><%= kosu.odemeler.surpriz %> TL</div>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-md-4 d-flex align-items-center justify-content-center">
              <div class="text-center p-3">
                <div style="font-size:2rem;">🏆</div>
                <div class="fw-bold" style="color:var(--hr-green);">#<%= kosu.odemeler.ganyanNo %> Kazandı</div>
                <div class="text-muted small"><%= kosu.odemeler.ganyanAt %></div>
                <div class="mt-2">
                  <span class="badge" style="background:#c8a400; color:#1a1a1e; font-size:0.9rem;">
                    <%= kosu.odemeler.ganyan %> TL
                  </span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <% } %> <!-- end if/else pending -->
      </div>
      <% }) %>

    </div>
    <% }) %>
  </div>

</div>

<%- include('partials/hr-footer') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
