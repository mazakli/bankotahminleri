  var _navMonths = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
  var _navDays   = ['Pazar','Pazartesi','Salı','Çarşamba','Perşembe','Cuma','Cumartesi'];
  var _navNow    = new Date(Date.now() + 3 * 60 * 60 * 1000);
  var _navDate   = _navNow.getUTCDate() + ' ' + _navMonths[_navNow.getUTCMonth()] + ' ' + _navNow.getUTCFullYear();
  var _navGun    = _navDays[_navNow.getUTCDay()];
  var _path      = typeof locals !== 'undefined' && locals.reqPath ? locals.reqPath : '';
%>
